  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "types": ["node"],
    "lib": ["ES2022"]
  },
  "include": [
    "electron.vite.config.ts",
    "electron/**/*.ts"
  ]
}
