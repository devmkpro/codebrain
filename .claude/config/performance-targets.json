{
  "version": "1.3.1",
  "targets": {
    "mcp": {
      "toolResponseTime": {
        "target": "<100ms p95",
        "description": "MCP tool execution latency",
        "measurement": "tool execution time",
        "priority": "high"
      },
      "totalTools": {
        "target": 91,
        "description": "Total registered MCP tools",
        "current": 91,
        "priority": "medium"
      },
      "bridgePattern": {
        "target": "3-tier",
        "description": "Bridge handler → index.js → mcp.ts wiring",
        "status": "implemented"
      }
    },
    "squads": {
      "maxWorkers": {
        "target": 8,
        "description": "Maximum workers per squad",
        "current": 8,
        "priority": "medium"
      },
      "spawnTime": {
        "target": "<2s",
        "description": "Worker spawn latency",
        "measurement": "pane_spawn execution time",
        "priority": "high"
      },
      "messageLatency": {
        "target": "<200ms",
        "description": "Inter-agent message delivery",
        "measurement": "pane_send_message latency",
        "priority": "high"
      },
      "memorySearchTime": {
        "target": "<50ms",
        "description": "Shared memory search latency",
        "measurement": "memory_search execution time",
        "priority": "high"
      }
    },
    "browser": {
      "navigationTime": {
        "target": "<3s",
        "description": "Page navigation + load",
        "measurement": "browser_navigate + wait_for_load",
        "priority": "medium"
      },
      "screenshotTime": {
        "target": "<1s",
        "description": "Screenshot capture latency",
        "measurement": "browser_screenshot execution time",
        "priority": "low"
      }
    },
    "skills": {
      "installTime": {
        "target": "<5s",
        "description": "Skill installation from registry",
        "measurement": "skill_install execution time",
        "priority": "medium"
      },
      "syncTime": {
        "target": "<10s",
        "description": "Full sync with GitLab registry",
        "measurement": "skill_sync execution time",
        "priority": "medium"
      }
    },
    "memory": {
      "storageLimit": {
        "target": "unlimited",
        "description": "SQLite-backed, no hard limit",
        "measurement": "disk usage",
        "priority": "low"
      },
      "searchAccuracy": {
        "target": ">90%",
        "description": "Memory search relevance",
        "measurement": "manual evaluation",
        "priority": "medium"
      }
    }
  },
  "phases": {
    "phase1": {
      "name": "Foundation",
      "status": "complete",
      "description": "Core MCP tools, memory system, basic squads"
    },
    "phase2": {
      "name": "Coordination",
      "status": "complete",
      "description": "Swarm coordination, pattern learning, trajectory tracking"
    },
    "phase3": {
      "name": "Skills & Browser",
      "status": "complete",
      "description": "Skills system, browser automation (30 tools), hooks"
    },
    "phase4": {
      "name": "Polish & Scale",
      "status": "in-progress",
      "description": "Performance optimization, advanced coordination, cloud sync"
    }
  },
  "monitoring": {
    "frequency": "continuous",
    "alerting": {
      "regressionThreshold": "10%",
      "criticalThreshold": "25%"
    }
  }
}
