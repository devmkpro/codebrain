# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── MCP (local runtime config, port changes per session) ─────────────────────
.mcp.json

# ── Claude Code local settings (personal permissions, not shared) ─────────────
.claude/settings.local.json

# ── GitLab Runner ────────────────────────────────────────────────────────────
config.toml
.runner_system_id
builds/

# ── Build output (all rebuilt by electron-vite build) ─────────────────────────
out/
dist/
*-bundle.js
*.tsbuildinfo

# ── Electron app / binaries (never commit) ────────────────────────────────────
*.exe
*.dll
*.asar
*.pak
*.bin
*.dat

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/settings.json

# ── Logs / temp ───────────────────────────────────────────────────────────────
*.log
npm-debug.log*
.tmp/

# ── Secrets / env ─────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── AI tool configs ───────────────────────────────────────────────────────────
.gemini/*
.claude/*
.codex/*
.copilot/*
.cursor/*
.openclaude/

# ── Temp build configs (electron-vite creates these sometimes) ────────────────
electron.vite.config.*.mjs

# ── Temp code snippets ───────────────────────────────────────────────────────
*.snippet
*.tail

# ── Codebrain pane system-prompt temp files ──────────────────────────────────
.codebrain-sys-*.txt

# ── Runtime artifacts (created by hooks/MCP during session) ──────────────────
"[hooks]"
500)

# ── Codebrain workspace data ─────────────────────────────────────────────────
.codebrain/

# ── Prebuild native binaries (copied by prebuild-native.mjs) ────────────────
resources/native/

# ── Bundled MCP stdio server (generated by bundle-stdio.mjs) ───────────────
resources/mcp-stdio/

# ── Decompilation utilities (one-time use) ──────────────────────────────────
decompile.mjs

# ── Local scripts (dev/build/release .bats) ─────────────────────────────────
local/
.github/*
